{
  "name": "commerce_review_mining",
  "description": "Collect product reviews/prices from commerce platforms.",
  "route": "commerce",
  "aliases": [
    "commerce",
    "shopping",
    "reviews"
  ],
  "intent_keywords": [
    "淘宝",
    "京东",
    "拼多多",
    "美团",
    "价格",
    "评价",
    "比价",
    "购买",
    "taobao",
    "jd",
    "pinduoduo",
    "meituan"
  ],
  "activation_keywords": [
    "淘宝",
    "京东",
    "拼多多",
    "美团",
    "taobao",
    "jd",
    "pinduoduo",
    "meituan",
    "价格",
    "评价",
    "比价",
    "购买",
    "review",
    "price"
  ],
  "min_activation_hits": 1,
  "min_score": 1.0,
  "priority": 84,
  "default_variables": {
    "platforms": [
      "taobao",
      "jd",
      "pinduoduo",
      "meituan"
    ]
  },
  "default_options": {
    "html_first": true,
    "crawl_assist": true,
    "use_browser": true,
    "top_results": 6
  },
  "examples": [
    "抓取 某型号 手机 在淘宝京东拼多多的评价差异",
    "分析同款商品在不同平台价格波动"
  ],
  "phases": [
    {
      "id": "intent",
      "title": "Intent Resolve",
      "goal": "识别商品、平台与比价维度"
    },
    {
      "id": "auth",
      "title": "Auth/Challenge Check",
      "goal": "确认是否有登录门槛或挑战页"
    },
    {
      "id": "dry_run",
      "title": "Compile & Lint",
      "goal": "dry-run 确认平台与抓取预算"
    },
    {
      "id": "execute",
      "title": "Execute",
      "goal": "执行抓取并输出价格/评价证据"
    }
  ]
}
