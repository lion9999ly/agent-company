{
  "_comment": "Google 搜索引擎配置",
  "id": "google",
  "name": "Google",
  "baseUrl": "https://www.google.com",
  "searchPath": "/search?q=",
  "selectors": {
    "resultContainer": ".g, div[data-sokoban-container], .Gx5Zad, .tF2Cxc, .hlcw0c",
    "title": "h3, .LC20lb, .DKV0Md",
    "link": "a, .yuRUbf a",
    "snippet": ".VwiC3b, div[data-sncf='1'], .s, .IsZvec"
  },
  "headers": {
    "Accept-Language": "zh-CN,zh;q=0.9,en;q=0.8"
  },
  "antiBot": {
    "enabled": true,
    "detectors": [
      "iframe[src*='recaptcha']",
      "div[data-ved] #captcha"
    ],
    "errorMessage": "Google 检测到 reCAPTCHA 验证，需要手动完成验证后重试。"
  },
  "customDelay": {
    "min": 1500,
    "max": 3500
  },
  "fallbackSelector": "div:has(a[href*='http']):not([role='navigation'])",
  "linkValidation": ["http"],
  "maxResultsPerPage": 10,
  "timezoneList": ["America/New_York", "America/Los_Angeles", "Europe/London", "Asia/Tokyo"],
  "localeList": ["en-US", "en-GB", "zh-CN", "ja-JP"]
}
