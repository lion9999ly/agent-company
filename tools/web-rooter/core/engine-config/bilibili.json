{
  "_comment": "Bilibili 搜索配置",
  "id": "bilibili",
  "name": "Bilibili",
  "baseUrl": "https://search.bilibili.com",
  "searchPath": "/all?keyword=",
  "selectors": {
    "resultContainer": "div.video-card, .bili-video-card, .video-list-item, .bili-video-card__wrap",
    "title": "a[href*='/video/'] h3, .bili-video-card__info--tit, a[href*='/video/']",
    "link": "a[href*='/video/']",
    "snippet": "span.desc, .bili-video-card__info--desc, p"
  },
  "headers": {
    "Accept-Language": "zh-CN,zh;q=0.9",
    "Referer": "https://www.bilibili.com/"
  },
  "antiBot": {
    "enabled": true,
    "detectors": [
      "[class*='captcha' i]",
      "[class*='verify' i]",
      "text=安全验证",
      "text=请先登录",
      "text=登录"
    ],
    "errorMessage": "Bilibili 检测到验证或登录门槛，需要补充本地登录态后重试。"
  },
  "customDelay": {
    "min": 1500,
    "max": 3200
  },
  "fallbackSelector": "div:has(a[href*='bilibili.com/video'])",
  "linkValidation": ["bilibili.com/video", "bilibili.com/read", "bilibili.com/opus"],
  "maxResultsPerPage": 20,
  "timezoneList": ["Asia/Shanghai"],
  "localeList": ["zh-CN"]
}
