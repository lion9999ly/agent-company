{
  "_comment": "小红书搜索配置",
  "id": "xiaohongshu",
  "name": "Xiaohongshu",
  "baseUrl": "https://www.xiaohongshu.com",
  "searchPath": "/search_result?keyword=",
  "selectors": {
    "resultContainer": "section.note-item, .note-item, .feeds-container section",
    "title": "a[href*='/explore/'] .title, .title span, .note-item .title, a[href*='/explore/']",
    "link": "a[href*='/explore/'], a[href*='/discovery/item/']",
    "snippet": ".desc, .note-text, .content, .note-item .desc"
  },
  "headers": {
    "Accept-Language": "zh-CN,zh;q=0.9",
    "Referer": "https://www.xiaohongshu.com/"
  },
  "antiBot": {
    "enabled": true,
    "detectors": [
      "[class*='captcha' i]",
      "[class*='verify' i]",
      "text=安全验证",
      "text=请完成验证",
      "text=请先登录"
    ],
    "errorMessage": "小红书检测到验证或登录门槛，需要补充本地登录态后重试。"
  },
  "customDelay": {
    "min": 2200,
    "max": 4200
  },
  "fallbackSelector": "section:has(a[href*='xiaohongshu.com/explore'])",
  "linkValidation": ["xiaohongshu.com/explore", "xiaohongshu.com/discovery/item", "xhslink.com"],
  "maxResultsPerPage": 20,
  "timezoneList": ["Asia/Shanghai"],
  "localeList": ["zh-CN"]
}
