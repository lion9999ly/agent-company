{
  "css_variables": {
    "colors": {
      "--color-normal": "#00FF41",
      "--color-caution": "#FFD700",
      "--color-danger": "#FF0000",
      "--color-info": "#00BFFF",
      "--color-inactive": "#666666",
      "--color-bg": "#000000",
      "--color-monochrome-green": "#00FF41"
    },
    "fonts": {
      "--font-family-primary": "'Roboto Mono', monospace",
      "--font-size-base": "16px",
      "--font-size-small": "0.75em",
      "--font-size-medium": "1em",
      "--font-size-large": "1.5em",
      "--font-size-huge": "2.5em",
      "--font-weight-normal": "400",
      "--font-weight-bold": "700"
    },
    "sizes": {
      "--spacing-unit": "8px",
      "--icon-size-small": "16px",
      "--icon-size-medium": "24px",
      "--icon-size-large": "32px",
      "--border-radius-small": "4px",
      "--border-radius-medium": "8px"
    }
  },
  "animation_timing": {
    "fade_in_out": {
      "duration": "0.3s",
      "easing": "ease-in-out"
    },
    "state_transition": {
      "duration": "0.4s",
      "easing": "ease-in-out"
    },
    "warning_flash": {
      "duration": "0.5s",
      "easing": "linear",
      "iterations": "infinite"
    },
    "icon_pulse": {
      "duration": "1s",
      "easing": "ease-in-out",
      "iterations": "infinite"
    }
  },
  "event_handlers": {
    "keyboard_mapping": {
      "call_accept": "Enter",
      "call_reject": "Escape",
      "music_play_pause": "Space",
      "music_next": "ArrowRight",
      "music_prev": "ArrowLeft",
      "menu_up": "ArrowUp",
      "menu_down": "ArrowDown",
      "menu_select": "Enter",
      "menu_back": "Escape"
    },
    "voice_commands": {
      "accept_call": "接听",
      "reject_call": "拒接",
      "play_music": "播放音乐",
      "pause_music": "暂停音乐",
      "next_song": "下一首",
      "previous_song": "上一首",
      "mute_navigation": "静音导航",
      "unmute_navigation": "开启导航语音"
    }
  },
  "speed_tier_rules": {
    "S0": {
      "range": "0",
      "max_elements": 6,
      "label": "静止"
    },
    "S1": {
      "range": "1-30",
      "max_elements": 4,
      "label": "低速"
    },
    "S2": {
      "range": "31-80",
      "max_elements": 3,
      "label": "中速"
    },
    "S3": {
      "range": "81+",
      "max_elements": 2,
      "label": "高速"
    }
  },
  "warning_flash": {
    "animation_name": "hud-warning-flash",
    "duration": "0.5s",
    "iterations": "infinite",
    "easing": "linear",
    "keyframes": [
      {
        "offset": 0,
        "background_color": "var(--color-danger)",
        "color": "var(--color-bg)"
      },
      {
        "offset": 0.5,
        "background_color": "var(--color-bg)",
        "color": "var(--color-danger)"
      },
      {
        "offset": 1,
        "background_color": "var(--color-danger)",
        "color": "var(--color-bg)"
      }
    ],
    "apply_to_regions_on_warning": true,
    "direction_mapping": {
      "front_left": [
        "LT"
      ],
      "front_right": [
        "RT"
      ],
      "front": [
        "LT",
        "RT"
      ],
      "rear_left": [
        "LB"
      ],
      "rear_right": [
        "RB"
      ],
      "rear": [
        "LB",
        "RB"
      ]
    }
  }
}